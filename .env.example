# App
AI_RECEPCIONISTA_APP_NAME=ai-recepcionista
AI_RECEPCIONISTA_ENVIRONMENT=development
AI_RECEPCIONISTA_LOG_LEVEL=INFO
AI_RECEPCIONISTA_VERSION=0.1.0

# Admin API
AI_RECEPCIONISTA_API_HOST=0.0.0.0
AI_RECEPCIONISTA_API_PORT=8000

# Asterisk / VICIdial placeholders for future milestones
AI_RECEPCIONISTA_STASIS_APP_NAME=ai-recepcionista
AI_RECEPCIONISTA_ARI_BASE_URL=
AI_RECEPCIONISTA_ARI_USERNAME=
AI_RECEPCIONISTA_ARI_PASSWORD=
AI_RECEPCIONISTA_AMI_HOST=
AI_RECEPCIONISTA_AMI_PORT=5038

# RTP / media placeholders
AI_RECEPCIONISTA_MEDIA_ADVERTISED_HOST=127.0.0.1
AI_RECEPCIONISTA_MEDIA_RTP_START_PORT=20000
AI_RECEPCIONISTA_MEDIA_RTP_END_PORT=20100

# Adapter placeholders
AI_RECEPCIONISTA_CALLBACKS_BACKEND=stub
AI_RECEPCIONISTA_DISPOSITIONS_BACKEND=stub
AI_RECEPCIONISTA_AUDIT_BACKEND=stub

# Worker
AI_RECEPCIONISTA_WORKER_HEARTBEAT_SECONDS=30

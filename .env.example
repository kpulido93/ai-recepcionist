APP_ENV=development
VOSK_COBRANZA_CONFIG=./config/ivr.yml
VOSK_COBRANZA_INTENTS=./config/intents.yml
VOSK_COBRANZA_LOGGING=./config/logging.yml
VOSK_WEBSOCKET_URL=ws://127.0.0.1:2700
VOSK_SAMPLE_RATE=8000
IVR_LISTEN_SECONDS=4
VOSK_MIN_RMS=150.0
LOG_LEVEL=INFO
LOG_PATH=./logs/vosk_cobranza.log
LOG_TRANSCRIPT=false
LOG_ROTATE_MAX_BYTES=10485760
LOG_ROTATE_BACKUP_COUNT=10
LAWYER_TRANSFER_CONTEXT=vicidial-transfer
LAWYER_TRANSFER_EXTEN=REEMPLAZAR_INGROUP_ABOGADOS
LAWYER_TRANSFER_PRIORITY=1

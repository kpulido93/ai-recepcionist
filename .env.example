APP_ENV=development
VOSK_COBRANZA_CONFIG=/opt/vicidial-vosk-cobranza-ivr/config/ivr.yml
VOSK_COBRANZA_INTENTS=/opt/vicidial-vosk-cobranza-ivr/config/intents.yml
VOSK_COBRANZA_LOGGING=/opt/vicidial-vosk-cobranza-ivr/config/logging.yml
VOSK_WEBSOCKET_URL=ws://127.0.0.1:2700
VOSK_SAMPLE_RATE=8000
VOSK_WEBSOCKET_TIMEOUT_SECONDS=10
IVR_LISTEN_SECONDS=4
VOSK_MIN_RMS=150.0
LOG_LEVEL=INFO
LOG_PATH=/var/log/asterisk/vosk_cobranza.log
LOG_TRANSCRIPT=false
LOG_ROTATE_MAX_BYTES=10485760
LOG_ROTATE_BACKUP_COUNT=10
LAWYER_TRANSFER_CONTEXT=REEMPLAZAR_CONTEXTO_TRANSFER
LAWYER_TRANSFER_EXTEN=REEMPLAZAR_INGROUP_O_EXTENSION
LAWYER_TRANSFER_PRIORITY=1
